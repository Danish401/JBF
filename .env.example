# Zoho OAuth — used by /api/zoho-token and Zoho Books PO fetch (same refresh token flow).
# Copy to .env or .env.local. Do not commit real secrets.
#
# Defaults use the US/global Zoho data center (zoho.com / zohoapis.com). For India (.in), set
# ZOHO_BOOKS_API_ROOT / ZOHO_INVENTORY_API_ROOT and regenerate tokens from accounts.zoho.in.
#
# If Books returns "You are not authorized to perform this operation", regenerate the refresh
# token with Books scopes in the browser consent URL, e.g.:
#   ZohoBooks.purchaseorders.READ,ZohoBooks.settings.READ
# (comma-separated). Use access_type=offline and prompt=consent.

ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=

# Optional. Default US/global token endpoint. Use https://accounts.zoho.in/oauth/v2/token only if your
# refresh token was issued from the India data center.
# ZOHO_OAUTH_TOKEN_URL=
#
# Access tokens (~1h) are obtained automatically: POST to the URL above with
# application/x-www-form-urlencoded body: refresh_token, client_id, client_secret, grant_type=refresh_token
# (see lib/zoho.ts — same in dev and production; no empty body).

# Organization ID (Books + Inventory use the same value when linked)
ZOHO_ORGANIZATION_ID=
# Legacy alias (optional if ZOHO_ORGANIZATION_ID is set)
ZOHO_BOOKS_ORGANIZATION_ID=

# books (default) = Zoho Books API. inventory = Zoho Inventory API (use for POs created in Inventory).
ZOHO_PURCHASE_ORDER_SOURCE=books

# Optional. Default US/global Books → https://www.zohoapis.com/books/v3
# India: https://www.zohoapis.in/books/v3   EU: https://www.zohoapis.eu/books/v3
ZOHO_BOOKS_API_ROOT=

# Optional. Default US/global Inventory → https://www.zohoapis.com/inventory/v1
# India: https://www.zohoapis.in/inventory/v1
ZOHO_INVENTORY_API_ROOT=

# Optional: overrides buyer name in header / ship-to when Zoho does not send attention
PO_BUYER_COMPANY_NAME=

# Optional: Vercel cron
# CRON_SECRET=
